   "source": [
    "import cv2\n",
    "\n",
    "color_img = cv2.imread(\"C:/Users/sudob/OneDrive/Desktop/week1/CAU.png\")\n",
    "gray_img = cv2.cvtColor(color_img, cv2.COLOR_BGR2GRAY)\n",
    "_, binary_img = cv2.threshold(gray_img, 100, 150, cv2.THRESH_BINARY)\n",
    "\n",
    "cv2.imshow(\"Color image\", binary_img)\n",
    "cv2.waitKey(0)\n"
   ],
